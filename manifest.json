{
  "manifest_version": 3,
  "name": "QuickPad",
  "description": "A simple notepad inside your browser. Paste, type, and save text instantly.",
  "version": "1.0",
  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "permissions": ["storage"]
}
